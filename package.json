    "naming",
    "standard",
    "validate-font-file-name",
    "validate-name",
    "validate",
    "validator"
  ],
  "packageManager": "pnpm@8.15.5",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "pnpm": ">=8.0.0"
  },
  "volta": {
    "node": "20.11.1",
    "pnpm": "8.15.5"
  },
  "type": "module",
  "types": "index.d.ts",
  "exports": {
    ".": "./index.js",
    "./*": "./commitlint.config.ts"
  },
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "scripts": {
    "init": "pnpm i && husky && git submodule update",
