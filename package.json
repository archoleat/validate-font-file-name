    "lint:md": "remark . --quiet",
    "lint:ts": "eslint index.ts --fix",
    "prettify": "prettier . --write",
    "commit": "cz"
  },
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@archoleat/semantic-release-define-config": "^1.1.0",
    "@commitlint/cli": "^18.6.1",
