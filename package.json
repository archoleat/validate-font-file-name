{
  "name": "@archoleat/validate-font-file-name",
  "description": "Checking font file names for standardization",
  "version": "1.0.0",
  "license": "MIT",
  "author": {
    "email": "archoleat@gmail.com",
    "name": "Archoleat",
    "url": "https://github.com/archoleat"
  },
  "homepage": "https://github.com/archoleat/validate-font-file-name#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archoleat/validate-font-file-name.git"
  },
  "bugs": {
    "url": "https://github.com/archoleat/validate-font-file-name/issues"
  },
  "keywords": [
    "archoleat",
    "font-file-name-standard",
